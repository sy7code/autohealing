<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console Log Appender (Azure Log Stream 호환) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- App Service 파일 시스템 로그 Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/home/LogFiles/Application/autohealing-app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rollover -->
            <fileNamePattern>/home/LogFiles/Application/autohealing-app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 30 days history -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <!-- 콘솔 출력 활성화 -->
        <appender-ref ref="STDOUT" />
        
        <!-- 프로덕션 환경(Azure)에서는 파일 로그도 추가 활성화 -->
        <springProfile name="prod">
             <appender-ref ref="FILE" />
        </springProfile>
    </root>

</configuration>

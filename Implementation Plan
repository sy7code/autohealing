```java
@Component
public class ScannerManager {
    // v17: 클래스 레벨 스레드 풀 (웹훅 n번 와도 스레드 3개만 재사용)
    private final ExecutorService executor = Executors.newFixedThreadPool(3);

    @PreDestroy // 서버 꺼질 때 Graceful Shutdown
    public void destroy() {
        executor.shutdown();
    }

    public List<UnifiedIssue> scanAll() {
        List<CompletableFuture<List<UnifiedIssue>>> futures = getActiveScanners().stream()
            .map(scanner -> CompletableFuture.supplyAsync(scanner::scan, executor)
                .exceptionally(ex -> {
                    log.error("[ScannerManager] {} 스캐너 실패 (무시됨)", scanner.scannerName(), ex);
                    return Collections.emptyList();
                }))
            .toList();
            
        return futures.stream()
            .map(CompletableFuture::join)
            .flatMap(List::stream)
            .toList();
    }
}
```

